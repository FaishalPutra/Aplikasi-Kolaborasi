// Schema bersama 3 modul. Tandai kepemilikan: [SHARED][P2P-PEOPLE][P2P-PROJECT][TEAM-FORM]
// Diisi mengikuti Conceptual Class Diagram TA (Gambar IV.16) + kebutuhan Affinity Engine (Bab IV.3).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// [SHARED] enum status
enum StatusProject {
  ACTIVE
  CLOSED
}

enum StatusPendaftaran {
  PENDING
  ACCEPTED
  REJECTED
  LEFT
}

// [SHARED]
model Mahasiswa {
  id        String   @id @default(cuid())
  nama      String
  email     String   @unique
  password  String                 // hash bcrypt (UC01/UC02)
  institusi String?                // asal kampus (wajib diisi lewat UC04 akun)
  jurusan   String?
  angkatan  Int?
  bio       String?
  kontak      String?               // ditampilkan ke pembuat saat diterima (UC11)
  kontakJenis String?               // "WHATSAPP" | "LINE" | "LINKEDIN" (platform kontak utama)
  createdAt DateTime @default(now())

  profil          Profil?
  projectsCreated Project[]              @relation("ProjectPembuat")
  pendaftaran     PendaftaranProject[]
  affinityScores  AffinityScoreProject[]

  treoProfil            TreoProfil?
  pendaftaranAnggota    PendaftaranAnggota[]
  affinityScoresTeam    AffinityScoreRoleTeam[]
}

// [SHARED] Profil kolaboratif — dasar Affinity Engine (UC04)
model Profil {
  id          String    @id @default(cuid())
  mahasiswaId String    @unique
  mahasiswa   Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  skill             String[] // tag multi-select
  pengalaman        Int      // skala ordinal 1..3 (Pemula/Menengah/Mahir)
  minatTag          String[] // tag multi-select
  gayaKerja         String   // "Terstruktur" | "Fleksibel"
  preferensiPeran   String   // "Leader/Coordinator" | "Contributor/Executor" | "Supporter/Facilitator"
  ketersediaanWaktu String[] // slot waktu multi-select (hard constraint)
  lengkap           Boolean  @default(false)
  visibilitas       Boolean  @default(true) // [P2P-PEOPLE] muncul di feed orang lain (UC05)
}

// [P2P-PROJECT]
model Project {
  id        String        @id @default(cuid())
  judul     String
  deskripsi String
  timeline  String?              // "Tenggat", mis. "5 hari lagi"
  durasi    String?              // mis. "3 bulan"
  format    String?              // "Online" | "Hybrid" | "Onsite"
  jadwalSlot String[]     // slot waktu kegiatan (untuk hard constraint filtering)
  // atribut sisi project untuk Affinity Engine (Algoritma 2)
  pengalamanReq Int      @default(1) // 1..3
  minatTag      String[]            // tag minat relevan kegiatan
  gayaKerja     String?             // preferensi gaya kerja kegiatan
  status    StatusProject @default(ACTIVE)
  createdAt DateTime      @default(now())

  pembuatId String
  pembuat   Mahasiswa @relation("ProjectPembuat", fields: [pembuatId], references: [id])

  roles          KebutuhanRole[]
  pendaftaran    PendaftaranProject[]
  affinityScores AffinityScoreProject[]
}

// [P2P-PROJECT] role + kuota per project
model KebutuhanRole {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  namaRole    String   // taksonomi generik: Leader/Coordinator, Contributor/Executor, Supporter/Facilitator
  skillDicari String[]
  kuota       Int
  sisaKuota   Int

  pendaftaran PendaftaranProject[]
}

// [P2P-PROJECT]
model PendaftaranProject {
  id          String            @id @default(cuid())
  mahasiswaId String
  projectId   String
  roleId      String
  status      StatusPendaftaran @default(PENDING)
  tanggal     DateTime          @default(now())

  mahasiswa Mahasiswa     @relation(fields: [mahasiswaId], references: [id])
  project   Project       @relation(fields: [projectId], references: [id])
  role      KebutuhanRole @relation(fields: [roleId], references: [id])

  @@unique([mahasiswaId, projectId])
}

// [P2P-PROJECT] hasil perhitungan Affinity Engine (UC05) — sumber feed (UC06)
model AffinityScoreProject {
  id          String   @id @default(cuid())
  mahasiswaId String
  projectId   String
  nilaiTotal  Float    // 0..1
  detail      Json     // breakdown kontribusi per atribut
  timestamp   DateTime @default(now())

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@unique([mahasiswaId, projectId])
}

// [P2P-PEOPLE] Skor affinity orang-ke-orang (Gambar IV.17). FK plain string (tanpa relasi navigasi).
model AffinityScorePeople {
  id           String   @id @default(cuid())
  mahasiswaAId String
  mahasiswaBId String
  nilaiTotal   Float
  detail       Json
  timestamp    DateTime @default(now())

  @@unique([mahasiswaAId, mahasiswaBId])
}

// [P2P-PEOPLE] UC09 — simpan profil calon partner
model SavedProfile {
  id       String   @id @default(cuid())
  ownerId  String   // yang menyimpan
  targetId String   // profil yang disimpan
  savedAt  DateTime @default(now())

  @@unique([ownerId, targetId])
}

// [P2P-PEOPLE] UC10 — express interest
model ExpressInterest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

// [P2P-PEOPLE] UC11 — connect request
model ConnectRequest {
  id         String            @id @default(cuid())
  senderId   String
  receiverId String
  status     StatusPendaftaran @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([senderId, receiverId])
}

// [P2P-PEOPLE] UC12 — koneksi mutual. Pasangan dinormalisasi (A<B) agar unik.
model Connection {
  id           String   @id @default(cuid())
  mahasiswaAId String
  mahasiswaBId String
  connectedAt  DateTime @default(now())
  asal         String   @default("REQUEST") // "INTEREST" (saling tertarik) | "REQUEST" (via Hubungkan)

  @@unique([mahasiswaAId, mahasiswaBId])
}

// [TEAM-FORM]
enum StatusLomba {
  ACTIVE
  CLOSED
}

enum StatusLobi {
  OPEN
  FINALIZING // pembuat tim sudah inisiasi finalisasi, menunggu semua anggota setuju
  FINAL
  CLOSED
}

// [TEAM-FORM] UC21 — usul lomba baru. Tanpa aktor Pengelola Platform: langsung ACTIVE saat diusulkan.
model Lomba {
  id            String      @id @default(cuid())
  judul         String
  deskripsi     String
  kategoriLomba String[]    // vocabulary sama dengan Profil.minatTag — req_minat(r) di Algoritma IV.1
  maxAnggotaTim Int
  minAnggotaTim Int?
  tenggat       DateTime?
  penyelenggara String?
  hadiah        String?     // mis. "Rp30 juta" — teks bebas, ditampilkan di kartu daftar lomba
  cakupan       String?     // "Nasional" | "Regional" | "Internasional"
  jenisBiaya    String?     // "GRATIS" | "BERBAYAR"
  nominalBiaya  String?     // mis. "Rp150.000" — diisi kalau jenisBiaya = "BERBAYAR"
  kontakInstagram  String?
  kontakWebsite    String?
  kontakNarahubung String?  // nama + nomor narahubung, teks bebas
  status        StatusLomba @default(ACTIVE)
  createdAt     DateTime    @default(now())
  pengusulId    String      // mahasiswa yang usul (plain FK, tanpa relasi navigasi)

  lobi          StudentLobby[]
}

// [TEAM-FORM] Lobi/tim yang dibentuk mahasiswa untuk mengikuti sebuah Lomba
model StudentLobby {
  id            String     @id @default(cuid())
  lombaId       String
  lomba         Lomba      @relation(fields: [lombaId], references: [id])
  judul         String
  deskripsi     String?
  koordinatorId String     // plain FK — pembuat lobi, murni administratif (bukan skor TREO)
  status        StatusLobi @default(OPEN)
  waktuInisiasiFinalisasi DateTime? // saat pembuat tim inisiasi finalisasi — dasar batas waktu 1 jam agar anggota menyetujui
  createdAt     DateTime   @default(now())

  roles         RoleLobiTim[]
  pendaftaran   PendaftaranAnggota[]
  pesan         DiskusiTim[]
  affinityRole  AffinityScoreRoleTeam[]
  skorTim       TeamFormationScore?
}

// [TEAM-FORM] role + kuota per lobi. namaRole dipilih dari Domain Skill Role sistem (bukan bebas isi)
model RoleLobiTim {
  id            String       @id @default(cuid())
  lobiId        String
  lobi          StudentLobby @relation(fields: [lobiId], references: [id], onDelete: Cascade)
  namaRole      String       // mis. "Data Analyst", "Backend Developer", "UI/UX Designer"
  pengalamanReq Int?         // 1..3, opsional — kalau null, atribut pengalaman dikeluarkan dari IV.1 (renormalize bobot skill/minat)
  kuota         Int
  sisaKuota     Int

  pendaftaran   PendaftaranAnggota[]
  affinityScore AffinityScoreRoleTeam[]
}

// [TEAM-FORM] pendaftaran mahasiswa ke sebuah role dalam lobi
model PendaftaranAnggota {
  id                String            @id @default(cuid())
  mahasiswaId       String
  lobiId            String
  roleId            String
  status            StatusPendaftaran @default(PENDING)
  setujuFinalisasi  Boolean           @default(false) // anggota ACCEPTED menyetujui inisiasi finalisasi tim
  dikeluarkan       Boolean           @default(false) // true jika status LEFT karena dikeluarkan koordinator, bukan keluar sendiri
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  mahasiswa Mahasiswa    @relation(fields: [mahasiswaId], references: [id])
  lobi      StudentLobby @relation(fields: [lobiId], references: [id])
  role      RoleLobiTim  @relation(fields: [roleId], references: [id])

  @@unique([mahasiswaId, lobiId])
}

// [TEAM-FORM] hasil Algoritma IV.1 (TechnicalRoleAffinity individu-role), dikunci saat diterima
model AffinityScoreRoleTeam {
  id          String   @id @default(cuid())
  mahasiswaId String
  lobiId      String
  roleId      String
  nilaiTotal  Float    // 0..1
  detail      Json
  timestamp   DateTime @default(now())

  mahasiswa Mahasiswa    @relation(fields: [mahasiswaId], references: [id])
  lobi      StudentLobby @relation(fields: [lobiId], references: [id])
  role      RoleLobiTim  @relation(fields: [roleId], references: [id])

  @@unique([mahasiswaId, lobiId, roleId])
}

// [TEAM-FORM] hasil Algoritma IV.3 di tingkat tim, cache untuk ditampilkan/diurutkan
model TeamFormationScore {
  id                      String       @id @default(cuid())
  lobiId                  String       @unique
  lobi                    StudentLobby @relation(fields: [lobiId], references: [id])
  technicalRoleAffinity   Float
  distributedRoleCoverage Float
  m                       Int
  teamFunctionAffinity    Float
  effectivenessScore      Float
  detail                  Json
  timestamp               DateTime     @default(now())
}

// [TEAM-FORM] jawaban kuesioner TREO (48 item Likert 1..5) + skor 6 dimensi per mahasiswa
model TreoProfil {
  id          String    @id @default(cuid())
  mahasiswaId String    @unique
  mahasiswa   Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  organizerRaw   Float @default(0)
  doerRaw        Float @default(0)
  challengerRaw  Float @default(0)
  innovatorRaw   Float @default(0)
  teamBuilderRaw Float @default(0)
  connectorRaw   Float @default(0)

  organizerNorm   Float @default(0)
  doerNorm        Float @default(0)
  challengerNorm  Float @default(0)
  innovatorNorm   Float @default(0)
  teamBuilderNorm Float @default(0)
  connectorNorm   Float @default(0)

  jawaban   Json    // 48 jawaban mentah {"organizer":[8 int],...}
  diisi     Boolean @default(false)
  updatedAt DateTime @updatedAt
}

// [TEAM-FORM] diskusi tim sederhana per lobi
model DiskusiTim {
  id          String       @id @default(cuid())
  lobiId      String
  lobi        StudentLobby @relation(fields: [lobiId], references: [id], onDelete: Cascade)
  mahasiswaId String       // plain FK
  pesan       String
  createdAt   DateTime     @default(now())
}
